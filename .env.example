# Copy to .env and fill in secrets:
#   cp .env.example .env
#
# DOCKER_UID / DOCKER_GID must match your host user (file permissions in ./services/*):
#   id -u && id -g

APP_NAME=KiddoPath

# ---------------------------------------------------------------------------
# Secrets — generate real values in .env, leave empty in this example file
# ---------------------------------------------------------------------------

# Django signing key (all services):
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Shared secret for service-to-service calls (X-Internal-Token header):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_SERVICE_TOKEN=

# OpenRouter (task-service AI classification):
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT=60
AI_CLASSIFY_THROTTLE=20/hour

# Google Sign-In (parents — GIS id_token flow)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------

DB_ENGINE=django.db.backends.postgresql
DB_NAME=transcendence
DB_USER=transcendence
DB_PASSWORD=transcendence
DB_HOST=db
DB_PORT=5432

# Per-service databases (created by `make init-dbs`)
AUTH_DB_NAME=auth_db
TASK_DB_NAME=task_db
GAMIFICATION_DB_NAME=gamification_db
ANALYTICS_DB_NAME=analytics_db
NOTIFICATION_DB_NAME=notification_db
CATALOG_DB_NAME=catalog_db

# ---------------------------------------------------------------------------
# Internal service URLs (Docker network hostnames, not secrets)
# ---------------------------------------------------------------------------

GAMIFICATION_INTERNAL_URL=http://gamification-service:8000
AUTH_INTERNAL_URL=http://auth-service:8000
ANALYTICS_INTERNAL_URL=http://analytics-service:8000
NOTIFICATION_INTERNAL_URL=http://notification-service:8000
TASK_SERVICE_URL=http://task-service:8000

# ---------------------------------------------------------------------------
# Docker image build (match host uid/gid)
# ---------------------------------------------------------------------------

DOCKER_UID=1000
DOCKER_GID=1000

# ---------------------------------------------------------------------------
# Email (auth-service)
# Default: console backend — logs to `docker compose logs auth-service`
# ---------------------------------------------------------------------------

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@localhost
FRONTEND_URL=https://localhost

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=30

# Optional auth-service tuning
# GUARDIAN_INVITE_EXPIRY_DAYS=7
# MAX_GUARDIANS_PER_KID=2
# EMAIL_VERIFICATION_EXPIRY_HOURS=24
