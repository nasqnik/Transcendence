# Copy to .env and adjust for your machine:
#   cp .env.example .env
#
# DOCKER_UID / DOCKER_GID must match your host user (file permissions in ./backend):
#   id -u && id -g

APP_NAME=KiddoPath

# Django — used for sessions, CSRF, JWT signing. Generate a new one for production:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-4fm1go9ub7b37y+uv5lvl7xf1%^j!1_&ta2iicye^qpdm=^%fh

# PostgreSQL (db service)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=transcendence
DB_USER=transcendence
DB_PASSWORD=transcendence
DB_HOST=db
DB_PORT=5432

# Backend image build (match host uid/gid)
# to check use those commands :
# id -u # -> DOCKER_UID
# id -g # -> DOCKER_GID
DOCKER_UID=1000
DOCKER_GID=1000

# ---------------------------------------------------------------------------
# Email
# Default: console backend (prints to `docker compose logs backend`, no real delivery).
# For real email, switch EMAIL_BACKEND to SMTP and fill the host settings below.
# ---------------------------------------------------------------------------

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

DEFAULT_FROM_EMAIL=noreply@localhost
FRONTEND_URL=https://localhost

# SMTP — examples:
#   Gmail:     EMAIL_HOST=smtp.gmail.com  EMAIL_PORT=587  EMAIL_USE_TLS=true
#              Use a Google "App password", not your normal login password.
#   SendGrid:  EMAIL_HOST=smtp.sendgrid.net  EMAIL_PORT=587  EMAIL_HOST_USER=apikey
#              EMAIL_HOST_PASSWORD=<your SendGrid API key>
#   Mailgun:   EMAIL_HOST=smtp.mailgun.org  (see Mailgun dashboard for credentials)

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=30

# Optional
# SERVER_EMAIL=noreply@yourdomain.com
# GUARDIAN_INVITE_EXPIRY_DAYS=7
# MAX_GUARDIANS_PER_KID=2


# Google Sign-In (parents only — GIS id_token flow)
# Required: Client ID from Google Cloud Console (Web application)
GOOGLE_CLIENT_ID=
# Not used for id_token verification (frontend GIS flow). Keep empty unless you add OAuth redirect later.
GOOGLE_CLIENT_SECRET=

DJANGO_SECRET_KEY=